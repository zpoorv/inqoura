rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasAdminRoleDocument() {
      return isSignedIn()
        && request.auth.token.email_verified == true
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == request.auth.token.email;
    }

    function isAdmin() {
      return isSignedIn()
        && (request.auth.token.admin == true || hasAdminRoleDocument());
    }

    function isOwnerProfileCreate(uid) {
      return isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.role == 'user'
        && request.resource.data.plan == 'free';
    }

    function isOwnerProfileUpdate(uid) {
      return isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.role == resource.data.role
        && request.resource.data.plan == resource.data.plan;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwnerProfileCreate(uid) || isAdmin();
      allow update: if isOwnerProfileUpdate(uid) || isAdmin();
      allow delete: if isOwner(uid) || isAdmin();

      match /scanHistory/{scanId} {
        allow read, create, update, delete: if isOwner(uid) || isAdmin();
      }
    }

    // Admin-authored product overrides can replace or enrich Open Food Facts data.
    match /productOverrides/{barcode} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /adminConfig/{configId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Feedback stays admin-readable and can later back a support dashboard.
    match /feedback/{feedbackId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }
  }
}
